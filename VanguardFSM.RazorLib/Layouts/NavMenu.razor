@inject IJSRuntime JS

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">VanguardFSM</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="dashboard">
                <span class="bi bi-kanban-fill-nav-menu" aria-hidden="true"></span> Dashboard
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="worker-dashboard">
                <span class="bi bi-tools-nav-menu" aria-hidden="true"></span> Worker Dashboard
            </NavLink>
        </div>

        @if (!isAuthenticated)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="login">
                    <span class="bi bi-box-arrow-in-right-nav-menu" aria-hidden="true"></span> Login
                </NavLink>
            </div>
        }

        @if (isAuthenticated)
        {
            <div class="nav-item px-3">
                <button class="btn btn-link nav-link text-start py-0" @onclick="Logout">Logout</button>
            </div>
        }
    </nav>
</div>

@code {
    private bool isAuthenticated;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "jwt");
            isAuthenticated = !string.IsNullOrEmpty(token);
            StateHasChanged();
        }
    }

    private async Task Logout()
    {
        await JS.InvokeVoidAsync("localStorage.removeItem", "jwt");
        await JS.InvokeVoidAsync("sessionStorage.removeItem", "jwt");
        isAuthenticated = false;
        NavigationManager.NavigateTo("/", true);
    }

    [Inject] public NavigationManager NavigationManager { get; set; } = default!;
}
