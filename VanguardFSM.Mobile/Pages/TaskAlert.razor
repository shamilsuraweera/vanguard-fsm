@*
    TaskAlert: Lightweight notification component.
    Real-time task alerts are now handled directly in WorkerDashboard.razor
    via SignalR "NewTaskAssigned" subscription. This component is retained
    for standalone notification display if needed outside the dashboard.
*@
@using VanguardFSM.Shared.Models

<div class="mobile-container">
    @if (Task != null)
    {
        <div class="card shadow-sm border-start border-warning mb-2" style="border-left-width: 4px">
            <div class="card-body p-3">
                <div class="d-flex justify-content-between align-items-center">
                    <h6 class="fw-bold mb-0">@Task.Title</h6>
                    <span class="badge bg-warning text-dark">New</span>
                </div>
                <p class="text-muted small mt-1 mb-2">@Task.Description</p>
                <button class="btn btn-success btn-sm w-100" @onclick="HandleAccept">
                    Accept Job
                </button>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public TaskItem? Task { get; set; }
    [Parameter] public EventCallback<int> OnAccepted { get; set; }

    private async Task HandleAccept()
    {
        if (Task != null)
        {
            await OnAccepted.InvokeAsync(Task.Id);
        }
    }
}
