@page "/worker-dashboard"
@using VanguardFSM.Shared.Models
@using VanguardFSM.Shared.Enums
@using System.Text.Json
@using NetTopologySuite.IO.Converters
@using Microsoft.AspNetCore.SignalR.Client
@inject HttpClient Http
@inject NavigationManager Navigation
@implements IAsyncDisposable

<div class="container mt-4">
    <div class="p-4 mb-4 bg-primary text-white rounded-3 shadow d-flex justify-content-between align-items-center">
        <div>
            <h2>Worker Dashboard</h2>
            @* Functionality: Gives the worker visual confirmation that their connection is live. *@
            <p class="mb-0">Status: @(hubConnection?.State == HubConnectionState.Connected ? "🟢 Live" : "🔴 Offline")</p>
        </div>
        
        @* Functionality: A real-time toast notification that pops up when the Hub sends an alert. *@
        @if (newNotification)
        {
            <div class="alert alert-warning mb-0 animate__animated animate__pulse infinite">
                <strong>New Task Assigned!</strong>
            </div>
        }
    </div>

    @if (assignedTasks == null)
    {
        <div class="spinner-border text-primary" role="status"></div>
    }
    else
    {
        <div class="row">
             @* Development: Filters the loaded tasks to only show ones currently sitting in the 'Dispatched' state *@
             @foreach (var task in assignedTasks.Where(t => t.Status == ServiceStatus.Dispatched))
            {
                <div class="col-md-6 mb-3">
                    <div class="card border-primary shadow">
                        <div class="card-body">
                            <h5 class="card-title text-primary">@task.Title</h5>
                            <p class="card-text">@task.Description</p>
                            
                            @* Functionality: Allows the worker to acknowledge the job, moving it to 'InProgress' *@
                            <button class="btn btn-success w-100" @onclick="() => AcceptTask(task.Id)">
                                Accept Job
                            </button>
                        </div>
                    </div>
                 </div>
            }
        </div>
    }
</div>

@code {
    private List<TaskItem>? assignedTasks;
    private HubConnection? hubConnection; // Development: The object managing the WebSocket connection
    private bool newNotification = false;
    
    private readonly JsonSerializerOptions _jsonOptions = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };

    protected override async Task OnInitializedAsync()
    {
        _jsonOptions.Converters.Add(new GeoJsonConverterFactory());

        // Development: 1. Build the SignalR connection string pointing to the API port.
        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("http://localhost:5085/notificationHub")) 
            .WithAutomaticReconnect()
            .Build();

        // Development: 2. Define the event listener. When the Hub shouts "NewTaskAssigned", execute this code.
        hubConnection.On<object>("NewTaskAssigned", async (data) =>
        {
            // Functionality: Triggers the UI alert and pulls fresh data from the database.
            newNotification = true;
            await LoadTasks(); 
            StateHasChanged(); // Force Blazor to redraw the screen
            
            // Functionality: Hides the yellow notification banner after 5 seconds.
            await Task.Delay(5000);
            newNotification = false;
            StateHasChanged();
        });

        // Development: 3. Actually start the WebSocket connection to the server.
        await hubConnection.StartAsync();
        await LoadTasks();
    }

    private async Task LoadTasks()
    {
        try {
            var result = await Http.GetFromJsonAsync<List<TaskItem>>("api/Dispatch/tasks", _jsonOptions);
            assignedTasks = result ?? new List<TaskItem>();
        } catch {
            assignedTasks = new List<TaskItem>();
        }
    }

    private async Task AcceptTask(int taskId)
    {
        var response = await Http.PostAsync($"api/Dispatch/accept-task/{taskId}", null);
        if (response.IsSuccessStatusCode)
        {
            await LoadTasks();
        }
    }

    // Development: Crucial cleanup to prevent memory leaks when the worker leaves the page.
    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }
}