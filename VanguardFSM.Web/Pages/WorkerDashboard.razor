@page "/worker-dashboard"
@using VanguardFSM.Shared.Models
@using VanguardFSM.Shared.Enums
@using System.Text.Json
@using NetTopologySuite.IO.Converters
@using Microsoft.AspNetCore.SignalR.Client
@using System.Net.Http.Headers
@using VanguardFSM.Web.Components
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="container mt-4">
    <div class="p-4 mb-4 bg-primary text-white rounded-3 shadow d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold mb-0">Worker Dashboard</h2>
            <small>Status: @(hubConnection?.State == HubConnectionState.Connected ? "🟢 Connected" : "🔴 Reconnecting...")</small>
        </div>
        
        @if (newNotification)
        {
            <div class="alert alert-warning mb-0 animate__animated animate__fadeInRight">
                <strong>New Job Available!</strong>
            </div>
        }
    </div>

    @if (activeTaskId != null)
    {
        @* Task 4.2: Show the Form if a task is being updated *@
        <div class="mb-4">
            <h4 class="text-secondary mb-3">Complete Work Report</h4>
            <ServiceEntryForm 
                UpdateModel="updateModel" 
                OnSave="HandleSaveUpdate" 
                OnCancel="() => activeTaskId = null" />
        </div>
    }
    else if (assignedTasks == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="text-muted mt-2">Loading assigned tasks...</p>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var task in assignedTasks.Where(t => t.Status == ServiceStatus.Dispatched || t.Status == ServiceStatus.InProgress))
            {
                <div class="col-md-6 mb-3">
                    <div class="card shadow-sm border-0 border-start @(task.Status == ServiceStatus.InProgress ? "border-primary" : "border-info")" style="border-left-width: 4px">
                        <div class="card-body">
                            <div class="d-flex justify-content-between">
                                <h5 class="card-title fw-bold">@task.Title</h5>
                                <span class="badge @(task.Status == ServiceStatus.InProgress ? "bg-primary" : "bg-info")">@task.Status</span>
                            </div>
                            <p class="text-muted small">@task.Description</p>

                            @if (task.Status == ServiceStatus.Dispatched)
                            {
                                <button class="btn btn-success w-100" @onclick="() => AcceptTask(task.Id)">
                                    Accept & Start Job
                                </button>
                            }
                            else if (task.Status == ServiceStatus.InProgress)
                            {
                                <button class="btn btn-primary w-100" @onclick="() => activeTaskId = task.Id">
                                    Log Work & Complete
                                </button>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<TaskItem>? assignedTasks;
    private HubConnection? hubConnection;
    private bool newNotification = false;
    
    // Task 4.2 State Management
    private int? activeTaskId;
    private ServiceUpdateModel updateModel = new();
    
    private readonly JsonSerializerOptions _jsonOptions = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };

    protected override async Task OnInitializedAsync()
    {
        _jsonOptions.Converters.Add(new GeoJsonConverterFactory());

        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("http://localhost:5085/notificationHub"), opts =>
            {
                // Passes the JWT from localStorage as a Bearer token on the WebSocket handshake.
                // Without this, [Authorize] on NotificationHub rejects the connection with 401.
                opts.AccessTokenProvider = async () => await JS.InvokeAsync<string>("localStorage.getItem", "jwt");
            })
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<object>("NewTaskAssigned", async (data) =>
        {
            newNotification = true;
            await LoadTasks();
            StateHasChanged();
            await Task.Delay(4000);
            newNotification = false;
            StateHasChanged();
        });

        try
        {
            await hubConnection.StartAsync();
        }
        catch (Exception)
        {
            // Connection failed (API down or not yet logged in); UI shows Reconnecting... status.
        }

        await EnsureAuthTokenAsync();
        await LoadTasks();
    }

    private async Task EnsureAuthTokenAsync()
    {
        var token = await JS.InvokeAsync<string>("localStorage.getItem", "jwt");
        if (!string.IsNullOrEmpty(token))
        {
            Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
        }
    }

    private async Task LoadTasks()
    {
        try
        {
            assignedTasks = await Http.GetFromJsonAsync<List<TaskItem>>("api/Dispatch/tasks", _jsonOptions);
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            // Not logged in yet; just pretend there are no tasks
            assignedTasks = new List<TaskItem>();
        }
        catch
        {
            assignedTasks = new List<TaskItem>();
        }
    }

    private async Task AcceptTask(int taskId)
    {
        var response = await Http.PostAsync($"api/Dispatch/accept-task/{taskId}", null);
        if (response.IsSuccessStatusCode)
        {
            await LoadTasks();
        }
    }

    // Task 4.2: Handling the Work Update submission
    private async Task HandleSaveUpdate(ServiceUpdateModel model)
    {
        if (activeTaskId == null) return;

        var response = await Http.PostAsJsonAsync($"api/Dispatch/update-work/{activeTaskId}", model);

        if (response.IsSuccessStatusCode)
        {
            activeTaskId = null; // Hide the form
            updateModel = new(); // Reset model for next use
            await LoadTasks();   // Refresh the task list
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null) await hubConnection.DisposeAsync();
    }
}