@page "/dashboard"
@using VanguardFSM.Shared.Models
@using VanguardFSM.Web.Components
@using System.Text.Json
@using NetTopologySuite.IO.Converters
@using Microsoft.JSInterop
@inject HttpClient Http
@inject IJSRuntime JS
@implements IDisposable

<div class="container mt-4">
    <div class="card shadow-sm mb-4">
        <div class="card-body d-flex justify-content-between align-items-center">
            <h3 class="card-title mb-0">Dispatcher Dashboard</h3>
            <div class="badge @(dbStatus == "Online" ? "bg-success" : "bg-danger") p-2">
                DB Status: @dbStatus | Tasks: @taskCount
            </div>
        </div>
    </div>

    @if (tasks == null)
    {
        <div class="d-flex align-items-center text-primary">
            <strong>Loading tasks...</strong>
            <div class="spinner-border ms-auto" role="status" aria-hidden="true"></div>
        </div>
    }
    else
    {
        <table class="table table-hover border shadow-sm">
            <thead class="table-dark">
                <tr>
                    <th>Task Name</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var task in tasks)
                {
                    <tr class="@(selectedTaskId == task.Id ? "table-primary" : "")">
                        <td>@task.Title</td>
                        <td><span class="badge bg-info">@task.Status</span></td>
                        <td>
                            <button class="btn btn-sm btn-primary" @onclick="() => FindWorkersForTask(task.Id)">
                                <i class="bi bi-search"></i> Find Nearby Workers
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    
    <div class="mt-4 border rounded shadow-sm overflow-hidden">
        <MapView @ref="mapComponent" />
    </div>
</div>

@code {
    private MapView? mapComponent;
    private List<TaskItem>? tasks;
    
    // Status tracking variables
    private string dbStatus = "Checking...";
    private int taskCount = 0;
    private string lastChecked = "";
    
    // Tracks which task is currently being assigned
    private int selectedTaskId; 
    
    // JavaScript reference for callbacks
    private DotNetObjectReference<Dashboard>? _dotNetRef;

    // JSON configuration required to read SQL spatial data
    private readonly JsonSerializerOptions _jsonOptions = new JsonSerializerOptions 
    { 
        PropertyNameCaseInsensitive = true 
    };

    protected override async Task OnInitializedAsync()
    {
        // 1. Initialize JSON converters and JS references
        _jsonOptions.Converters.Add(new GeoJsonConverterFactory());
        _dotNetRef = DotNetObjectReference.Create(this);

        // 2. Load initial data
        await RefreshDbStatus();
        await LoadTasks();
    }

    private async Task LoadTasks()
    {
        try 
        {
            tasks = await Http.GetFromJsonAsync<List<TaskItem>>("api/Dispatch/tasks", _jsonOptions);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading tasks: {ex.Message}");
        }
    }

    private async Task RefreshDbStatus()
    {
        try 
        {
            var result = await Http.GetFromJsonAsync<DbCheckResponse>("api/Dispatch/db-check");
            if (result != null) 
            {
                dbStatus = result.Status;
                taskCount = result.TotalTasks;
                lastChecked = result.Timestamp;
            }
        } 
        catch 
        {
            dbStatus = "Offline";
        }
    }

    private async Task FindWorkersForTask(int taskId)
    {
        // Remember the ID so we know what task to assign later
        selectedTaskId = taskId; 
        
        var nearbyWorkers = await Http.GetFromJsonAsync<List<User>>($"api/Dispatch/suggest-workers/{taskId}/5000", _jsonOptions);

        if (nearbyWorkers != null)
        {
            foreach (var worker in nearbyWorkers)
            {
                if (worker.LastKnownLocation != null)
                {
                    // Pass the worker data and the C# reference to our JavaScript map file
                    await JS.InvokeVoidAsync("mapFunctions.addWorkerMarker", 
                        worker.LastKnownLocation.Y, 
                        worker.LastKnownLocation.X, 
                        worker.Name, 
                        worker.Id, 
                        _dotNetRef);
                }
            }
        }
    }

    [JSInvokable] // This exposes the method so JavaScript can click it
    public async Task HandleAssignTask(int workerId)
    {
        if (selectedTaskId == 0) return;

        // Call the API to update the database and trigger SignalR
        var response = await Http.PostAsync($"api/Dispatch/assign-task/{selectedTaskId}/{workerId}", null);

        if (response.IsSuccessStatusCode)
        {
            // Reset the selection and refresh the table
            selectedTaskId = 0;
            await LoadTasks();
            StateHasChanged(); // Force the UI to update
        }
        else 
        {
            Console.WriteLine("Failed to assign task.");
        }
    }

    // Clean up memory when the component is destroyed
    public void Dispose()
    {
        _dotNetRef?.Dispose();
    }

    // Helper class for the DB check
    public class DbCheckResponse 
    {
        public string Status { get; set; } = "";
        public int TotalTasks { get; set; }
        public string Timestamp { get; set; } = "";
    }
}