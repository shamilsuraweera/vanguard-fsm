@page "/dashboard"
@using VanguardFSM.Shared.Models
@using VanguardFSM.Shared.Enums
@using VanguardFSM.Web.Components
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.SignalR.Client
@inject NavigationManager Navigation
@inject HttpClient Http
@inject IJSRuntime JS
@implements IAsyncDisposable 

@using System.Net.Http.Headers

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="text-primary fw-bold mb-0">Dispatcher Dashboard</h3>
        
        @* Functionality: Confirms the Dispatcher is successfully connected to the real-time Hub *@
        <span class="badge @(hubConnection?.State == HubConnectionState.Connected ? "bg-success" : "bg-danger") p-2 shadow-sm">
            SignalR: @(hubConnection?.State == HubConnectionState.Connected ? "Connected" : "Disconnected")
        </span>
    </div>

    @if (tasks == null)
    {
        <div class="text-center my-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Connecting to Service...</p>
        </div>
    }
    else
    {
        <KanbanBoard Tasks="tasks" 
                     OnTaskSelected="FindWorkersForTask" 
                     OnStatusChanged="UpdateTaskStatus" />
    }

    <div class="mt-4 border rounded shadow-sm bg-white overflow-hidden">
        <div class="bg-light p-2 border-bottom">
            <small class="text-secondary fw-bold text-uppercase">Geographic Dispatch Map</small>
        </div>
        <MapView @ref="mapComponent" />
    </div>
</div>

@code {
    private MapView? mapComponent;
    private List<TaskItem>? tasks;
    private int selectedTaskId;
    private DotNetObjectReference<Dashboard>? _dotNetRef;
    
    // Development: Added HubConnection so the Dispatcher can push events out.
    private HubConnection? hubConnection;

    protected override async Task OnInitializedAsync()
    {
        _dotNetRef = DotNetObjectReference.Create(this);
        
        // Development: Establish connection to the Hub.
        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("http://localhost:5085/notificationHub"), opts =>
            {
                // Passes the JWT from localStorage as a Bearer token on the WebSocket handshake.
                // Without this, [Authorize] on NotificationHub rejects the connection with 401.
                opts.AccessTokenProvider = async () => await JS.InvokeAsync<string>("localStorage.getItem", "jwt");
            })
            .WithAutomaticReconnect()
            .Build();

        try
        {
            await hubConnection.StartAsync();
        }
        catch (Exception)
        {
            // Connection failed (API down or not yet logged in); UI shows Disconnected badge.
        }

        await EnsureAuthTokenAsync();
        await LoadTasks();
    }

    private async Task EnsureAuthTokenAsync()
    {
        var token = await JS.InvokeAsync<string>("localStorage.getItem", "jwt");
        if (!string.IsNullOrEmpty(token))
        {
            Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
        }
    }

    private async Task LoadTasks()
    {
        try {
            tasks = await Http.GetFromJsonAsync<List<TaskItem>>("api/Dispatch/tasks");
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            // not authenticated; show empty list
            tasks = new List<TaskItem>(); 
        }
        catch {
            tasks = new List<TaskItem>(); 
        }
    }

    private async Task UpdateTaskStatus((int TaskId, ServiceStatus NewStatus) updateData)
    {
        await Http.PutAsJsonAsync($"api/Dispatch/update-status/{updateData.TaskId}", updateData.NewStatus);
        await LoadTasks();
    }

    private async Task FindWorkersForTask(int taskId)
    {
        selectedTaskId = taskId;
        var workers = await Http.GetFromJsonAsync<List<User>>($"api/Dispatch/suggest-workers/{taskId}/5000");
        
        if (workers != null && mapComponent != null && _dotNetRef != null)
        {
            foreach (var w in workers)
            {
                if (w.LastKnownLocation != null)
                {
                    await mapComponent.AddWorkerMarker(w.LastKnownLocation.Y, w.LastKnownLocation.X, w.Name, w.Id, _dotNetRef);
                }
            }
        }
    }

    // Functionality: Triggered by JavaScript when the 'Assign Task' button in the map popup is clicked.
    [JSInvokable]
    public async Task HandleAssignTask(int workerId)
    {
        if (selectedTaskId == 0) return;
        
        // 1. Update the Database via the REST API
        var response = await Http.PostAsync($"api/Dispatch/assign-task/{selectedTaskId}/{workerId}", null);
        
        if (response.IsSuccessStatusCode)
        {
            // Development: Grab the title of the task we just assigned to send in our payload.
            var assignedTask = tasks?.FirstOrDefault(t => t.Id == selectedTaskId);
            string title = assignedTask?.Title ?? "New Task";

            // 2. Broadcast the Real-Time Alert via SignalR
            // Functionality: This instantly tells the Worker Dashboard to refresh its screen.
            if (hubConnection is not null && hubConnection.State == HubConnectionState.Connected)
            {
                await hubConnection.InvokeAsync("SendTaskAssignment", workerId, title);
            }

            // 3. Clean up the Dispatcher UI
            selectedTaskId = 0;
            await LoadTasks();
            StateHasChanged();
        }
    }

    // Development: Safely close connections and memory references when navigating away.
    public async ValueTask DisposeAsync()
    {
        _dotNetRef?.Dispose();
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }
}