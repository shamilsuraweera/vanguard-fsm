@page "/"
@inject NavigationManager Navigation

<PageTitle>VanguardFSM - Field Service Management</PageTitle>

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="text-center mt-5">
                <h1 class="display-4 text-primary mb-4">VanguardFSM</h1>
                <p class="lead mb-4">Advanced Field Service Management System</p>
                <p class="mb-4">Manage service requests, track field workers, and coordinate dispatch operations in real-time.</p>

                <div class="d-grid gap-3 d-md-flex justify-content-md-center">
                    <button class="btn btn-primary btn-lg me-md-2" @onclick="NavigateToDashboard">
                        <i class="bi bi-kanban-fill me-2"></i>Dispatcher Dashboard
                    </button>
                    <button class="btn btn-outline-primary btn-lg" @onclick="NavigateToWorkerDashboard">
                        <i class="bi bi-tools me-2"></i>Worker Dashboard
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private void NavigateToDashboard()
    {
        Navigation.NavigateTo("/dashboard");
    }

    private void NavigateToWorkerDashboard()
    {
        Navigation.NavigateTo("/worker-dashboard");
    }
}