@using Microsoft.JSInterop
@using VanguardFSM.Web.Pages
@inject IJSRuntime JS

<div id="map" style="height: 400px; width: 100%; border-radius: 8px;"></div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Initializes the Leaflet map in the 'map' div
            await JS.InvokeVoidAsync("mapFunctions.initialize", "map", 51.505, -0.09);
        }
    }

    public async Task AddWorkerMarker(double lat, double lng, string name, int id, DotNetObjectReference<Dashboard> reference)
    {
        // Passes the C# reference to JS so the button can call back
        await JS.InvokeVoidAsync("mapFunctions.addWorkerMarker", lat, lng, name, id, reference);
    }
}